# Mode: "local" (default) runs the bundled collector + SQLite.
# Set to "core" to point at a remote NetwatchCore backend.
NEXT_PUBLIC_NETWATCH_SOURCE=local

# Only used when NEXT_PUBLIC_NETWATCH_SOURCE=core
NEXT_PUBLIC_NETWATCH_CORE_URL=http://localhost:3001

# Marketing/OG links (hosted mode).
NEXT_PUBLIC_APP_URL=https://netwatchlabs.com

# Standalone-mode-only. If unset, an API key is auto-generated on first start
# and written to $NETWATCH_DASHBOARD_DATA_DIR/config.json (default ~/.netwatch-dashboard).
# NETWATCH_DASHBOARD_API_KEY=ndk_...

# Standalone-mode-only. Where SQLite + config live. In Docker the image sets /data.
# NETWATCH_DASHBOARD_DATA_DIR=/data
